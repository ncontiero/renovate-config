{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigestsToSemver",
    ":configMigration",
    "abandonments:recommended",
    ":maintainLockFilesWeekly",
    ":disableRateLimiting",
    ":disablePeerDependencies",
    "group:githubArtifactActions"
  ],
  "schedule": [
    "* 3-6 * * 0"
  ],
  "rangeStrategy": "bump",
  "minimumReleaseAge": "3 days",
  "semanticCommits": "enabled",
  "commitMessageTopic": "{{depName}}",
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "* 0-3 * * 1"
    ],
    "automerge": true
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "enabled": false,
      "matchDepTypes": ["engines"],
      "matchPackageNames": ["node"]
    },
    {
      "matchPackageNames": ["*"],
      "semanticCommitType": "chore"
    },
    {
      "groupName": "clerk monorepo",
      "matchSourceUrls": ["https://github.com/clerk/javascript"],
      "matchUpdateTypes": ["major"]
    },
    {
      "groupName": "rspress monorepo",
      "matchSourceUrls": ["https://github.com/web-infra-dev/rspress"],
      "matchUpdateTypes": ["major"]
    },
    {
      "groupName": "t3-env monorepo",
      "matchSourceUrls": ["https://github.com/t3-oss/t3-env"],
      "matchUpdateTypes": ["major"]
    },
    {
      "groupName": "contentlayer2 monorepo",
      "matchSourceUrls": ["https://github.com/timlrx/contentlayer2"],
      "matchUpdateTypes": ["major"]
    },
    {
      "groupName": "changesets monorepo",
      "matchSourceUrls": ["https://github.com/changesets/changesets/"],
      "matchUpdateTypes": ["major"]
    },
    {
      "groupName": "trigger.dev monorepo",
      "matchSourceUrls": ["https://github.com/triggerdotdev/trigger.dev"],
      "matchUpdateTypes": ["major"]
    },
    {
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "all digest updates",
      "groupSlug": "all-digest",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["digest"]
    }
  ],
  "pip_requirements": {
    "managerFilePatterns": ["/(^|/)[\\w-]*requirements([./_-][\\w-]+)?\\.(txt|pip)$/"]
  }
}
